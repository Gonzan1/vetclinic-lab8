<div class="card mb-4">
  <div class="card-body">
    <h2 class="card-title"><%= "#{@vet.first_name} #{@vet.last_name}" %></h2>
    <p><strong>Email:</strong> <%= @vet.email %></p>
    <p><strong>Phone:</strong> <%= @vet.phone %></p>
    <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
  </div>
</div>

<h3>Upcoming Appointments</h3>
<ul class="list-group mb-4">
  <% @vet.appointments.upcoming.each do |app| %>
    <li class="list-group-item list-group-item-info">
      <%= link_to "#{human_datetime(app.date)} - Pet: #{app.pet.name}", appointment_path(app) %>
    </li>
  <% end %>
</ul>

<h3>Past Appointments</h3>
<ul class="list-group mb-4">
  <% @vet.appointments.past.each do |app| %>
    <li class="list-group-item text-muted">
      <%= link_to "#{human_datetime(app.date)} - Pet: #{app.pet.name}", appointment_path(app) %>
    </li>
  <% end %>
</ul>

<br>
<%= link_to 'Back to Vets', vets_path, class: "btn btn-secondary" %>

<div class="mt-4 d-flex gap-2">
  <%= link_to 'Edit', edit_vet_path(@vet), class: "btn btn-warning" %>
  <%= button_to 'Delete', @vet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
  <%= link_to 'Back to Vets', vets_path, class: "btn btn-secondary" %>
</div>