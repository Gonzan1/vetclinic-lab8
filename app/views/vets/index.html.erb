<h1>Veterinarians</h1>

<%= link_to 'New Vet', new_vet_path, class: "btn btn-success mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Specialization</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= vet.full_name %></td>
        <td><%= vet.specialization %></td>
        <td>
          <%= link_to 'View', vet, class: "btn btn-sm btn-primary" %>
          <%= link_to 'Edit', edit_vet_path(vet), class: "btn btn-sm btn-warning" %>
          <%= button_to 'Delete', vet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger mt-1" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>