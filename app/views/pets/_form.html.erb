<%= form_with(model: @pet, class: "mb-4") do |form| %>
  <%= render 'shared/error_messages', object: @pet %>

  <div class="mb-3">
    <%= form.label :name, "Name", class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :species, "Species", class: "form-label" %>
    <%= form.select :species, ['dog', 'cat', 'rabbit', 'bird', 'reptile', 'other'], { prompt: "Select a species" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :breed, "Breed", class: "form-label" %>
    <%= form.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :weight, "Weight (kg)", class: "form-label" %>
    <%= form.number_field :weight, step: :any, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :date_of_birth, "Date of Birth", class: "form-label" %>
    <%= form.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :owner_id, "Owner", class: "form-label" %>
    <%= form.collection_select :owner_id, Owner.all, :id, :full_name, { prompt: "Select an owner" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :photo, "Pet Photo", class: "form-label" %>
    
    <% if pet.photo.attached? %>
      <div class="mb-2">
        <span class="d-block text-muted small mb-1">Current photo:</span>
        <%= image_tag pet.photo, style: "width: 100px;", class: "img-thumbnail" %>
      </div>
    <% end %>

    <%= form.file_field :photo, class: "form-control" %>
  </div>

  <%= form.submit class: "btn btn-primary" %>
  <%= link_to 'Cancel', pets_path, class: "btn btn-secondary ms-2" %>
<% end %>