<h1>Pets</h1>

<%= link_to 'New Pet', new_pet_path, class: "btn btn-success mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Owner</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= pet.name %></td>
        <td><%= pet.species %></td>
        <td><%= pet.owner.full_name if pet.owner %></td>
        <td>
          <%= link_to 'View', pet, class: "btn btn-sm btn-primary" %>
          <%= link_to 'Edit', edit_pet_path(pet), class: "btn btn-sm btn-warning" %>
          <%= button_to 'Delete', pet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger mt-1" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>