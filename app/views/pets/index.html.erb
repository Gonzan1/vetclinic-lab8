<h1>Pets</h1>
<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Name</th><th>Species</th><th>Breed</th><th>Owner</th><th>Date of Birth</th><th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= pet.name %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= "#{pet.owner.first_name} #{pet.owner.last_name}" %></td>
        <td><%= human_date(pet.date_of_birth) %></td>
        <td><%= link_to 'View Details', pet_path(pet), class: "btn btn-sm btn-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>