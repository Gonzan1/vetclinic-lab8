
<div class="card mb-4">
  <div class="card-body">
    <div class="row">
      
      <div class="col-md-8">
        <h2 class="card-title mb-3"><%= @pet.name %></h2>
        
        <p class="card-text"><strong>Species:</strong> <%= @pet.species %></p>
        <p class="card-text"><strong>Breed:</strong> <%= @pet.breed %></p>
        <p class="card-text"><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") if @pet.date_of_birth %></p>
        <p class="card-text"><strong>Weight:</strong> <%= @pet.weight %> kg</p>
        <p class="card-text"><strong>Owner:</strong> <%= link_to @pet.owner.first_name, @pet.owner %></p>
      </div>

      <div class="col-md-4 text-end">
        <% if @pet.photo.attached? %>
          <%= image_tag @pet.photo, class: "img-fluid rounded border shadow-sm", style: "max-height: 250px; object-fit: cover;" %>
        <% else %>
          <div class="bg-light border rounded d-flex align-items-center justify-content-center ms-auto shadow-sm" style="width: 200px; height: 200px;">
            <span class="text-muted fst-italic">No photo available</span>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>

<h3>Upcoming Appointments</h3>
<ul class="list-group mb-4">
  <% @pet.appointments.upcoming.each do |app| %>
    <li class="list-group-item list-group-item-info">
      <%= link_to "#{human_datetime(app.date)} - #{app.reason}", appointment_path(app) %>
    </li>
  <% end %>
</ul>

<h3>Past Appointments</h3>
<ul class="list-group mb-4">
  <% @pet.appointments.past.each do |app| %>
    <li class="list-group-item text-muted">
      <%= link_to "#{human_datetime(app.date)} - #{app.reason}", appointment_path(app) %>
    </li>
  <% end %>
</ul>

<br>
<%= link_to 'Back to Pets', pets_path, class: "btn btn-secondary" %>

<div class="mt-4 d-flex gap-2">
  <%= link_to 'Edit', edit_pet_path(@pet), class: "btn btn-warning" %>
  <%= button_to 'Delete', @pet, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
  <%= link_to 'Back to Pets', pets_path, class: "btn btn-secondary" %>
</div>