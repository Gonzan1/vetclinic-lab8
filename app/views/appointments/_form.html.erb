<%= form_with(model: @appointment, class: "mb-4") do |form| %>
  <%= render 'shared/error_messages', object: @appointment %>

  <div class="mb-3">
    <%= form.label :date, "Date and Time", class: "form-label" %>
    <%= form.datetime_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :reason, "Reason", class: "form-label" %>
    <%= form.text_area :reason, class: "form-control", rows: 3 %>
  </div>

    <% if @appointment.persisted? %>
    <div class="mb-3">
      <%= form.label :status, "Status", class: "form-label" %>
      <%= form.select :status, Appointment.statuses.keys, { prompt: "Select a status" }, class: "form-select" %>
    </div>
    <% end %>


  <div class="mb-3">
    <%= form.label :pet_id, "Pet", class: "form-label" %>
    <%= form.collection_select :pet_id, Pet.all, :id, :name, { prompt: "Select a pet" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :vet_id, "Veterinarian", class: "form-label" %>
    <%= form.collection_select :vet_id, Vet.all, :id, :full_name, { prompt: "Select a vet" }, class: "form-select" %>
  </div>

  <%= form.submit class: "btn btn-primary" %>
  <%= link_to 'Cancel', appointments_path, class: "btn btn-secondary ms-2" %>
<% end %>