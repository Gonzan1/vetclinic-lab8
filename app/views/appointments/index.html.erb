<h1>Appointments</h1>

<%= link_to 'New Appointment', new_appointment_path, class: "btn btn-success mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Veterinarian</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y - %H:%M") %></td>
        <td><%= appointment.pet.name if appointment.pet %></td>
        <td><%= appointment.vet.full_name if appointment.vet %></td>
        <td>
          <% badge_color = case appointment.status
                           when 'scheduled' then 'bg-primary'
                           when 'in_progress' then 'bg-warning text-dark'
                           when 'completed' then 'bg-success'
                           when 'cancelled' then 'bg-danger'
                           else 'bg-secondary'
                           end %>
          <span class="badge <%= badge_color %>"><%= appointment.status.titleize %></span>
        </td>
        <td>
          <%= link_to 'View', appointment, class: "btn btn-sm btn-primary" %>
          <%= link_to 'Edit', edit_appointment_path(appointment), class: "btn btn-sm btn-warning" %>
          <%= button_to 'Delete', appointment, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger mt-1" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>